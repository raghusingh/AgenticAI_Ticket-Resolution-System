APP_NAME=ChatOps RAG Product
APP_ENV=dev
API_PREFIX=/api/v1

# LLM / Embedding keys
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=your-openai-api-key

# ── Auto-closure ─────────────────────────────────────────────────────────────
# Minimum RAG confidence score (0–1) to automatically close a ticket.
# Tickets scoring below this threshold are routed for human review.
AUTO_CLOSE_CONFIDENCE_THRESHOLD=0.85

# ── SMTP Notification ────────────────────────────────────────────────────────
# When SMTP_HOST is set, real e-mails are sent.
# Leave blank to use mock/log mode (HTML table logged to console).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourcompany.com
