APP_NAME=ChatOps RAG Product
APP_ENV=dev
API_PREFIX=/api/v1
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ── Auto-closure ─────────────────────────────────────────────────────────────
# Minimum RAG confidence score (0–1) to automatically close a ticket.
# Tickets scoring below this are routed for human review.
AUTO_CLOSE_CONFIDENCE_THRESHOLD=0.85

# ── SMTP Notification ────────────────────────────────────────────────────────
# Leave blank to use mock/log mode (logs HTML table to console).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourcompany.com

# ── Auto-closure ──────────────────────────────────────────────────────────────
AUTO_CLOSE_CONFIDENCE_THRESHOLD=0.85

# ── SMTP Notification ─────────────────────────────────────────────────────────
# Leave blank to use mock/log mode (table printed to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourcompany.com

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_JIRA_INTERVAL_MINUTES=5
SCHEDULER_SHAREPOINT_INTERVAL_MINUTES=5

# CC recipients — comma-separated, leave blank for no CC
SMTP_CC=
